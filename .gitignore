# Dependências do Node (nunca subir, pois são baixadas com 'npm install')
node_modules/
jspm_packages/
web_modules/

# Arquivos de Variáveis de Ambiente (Segurança: contém chaves e senhas)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Pasta de Compilação/Build (Arquivos JS gerados automaticamente pelo tsup/tsc)
dist/
build/
out/

# Logs do NPM e Erros
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Configurações locais do VS Code e editores
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Arquivos de sistema operacional (arquivos invisíveis que o Windows/Mac criam)
Thumbs.db
.DS_Store
